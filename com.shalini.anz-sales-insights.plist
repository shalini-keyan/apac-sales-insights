<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <key>Label</key>
  <string>com.shalini.anz-sales-insights</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>/Users/shalini.keyan/Cursor\ Workspaces/outline/anz-sales-insights/deploy.sh >> /tmp/anz-sales-insights.log 2>&amp;1</string>
  </array>

  <!-- Every Monday at 11:00 AM -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>11</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/tmp/anz-sales-insights.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/anz-sales-insights.log</string>

</dict>
</plist>
